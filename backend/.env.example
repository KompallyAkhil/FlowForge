# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# AI Provider
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=YOUR-API-KEY-HERE
# OPENROUTER_MODEL=YOUR-MODEL-HERE

AI_PROVIDER=groq
GROQ_API_KEY=YOUR-API-KEY-HERE
GROQ_MODEL=YOUR-MODEL-HERE



# Memory
MEMORY_MAX_ITEMS=100

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000



# Option B: OAuth2 Refresh Token (personal Gmail / standard Google account)
# Get these from Google Cloud Console → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=YOUR-API-KEY-HERE
GOOGLE_CLIENT_SECRET=YOUR-API-KEY-HERE
GOOGLE_REFRESH_TOKEN=YOUR-API-KEY-HERE

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create a Slack App → OAuth & Permissions → Bot Token (xoxb-...)
SLACK_BOT_TOKEN=YOUR-API-KEY-HERE
SLACK_DEFAULT_CHANNEL=#Your-Default-Channel

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Copy the ID from your Sheets URL: docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/
SHEETS_SPREADSHEET_ID=YOUR-API-KEY-HERE
